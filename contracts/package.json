{
  "name": "@azcred/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "AzCred smart contracts — ERC-8004 registries and AzCredCreditLine",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deployAll.ts --network creditcoin_testnet",
    "deploy:registries": "hardhat run scripts/deployRegistries.ts --network creditcoin_testnet",
    "deploy:azcred": "hardhat run scripts/deployAzCred.ts --network creditcoin_testnet",
    "seed": "hardhat run scripts/seedTestAgents.ts --network creditcoin_testnet",
    "seed:more": "hardhat run scripts/seedMoreAgents.ts --network creditcoin_testnet",
    "verify": "hardhat run scripts/verifyDeployment.ts --network creditcoin_testnet",
    "verify:contracts": "hardhat run scripts/verifyContracts.ts --network creditcoin_testnet",
    "test:coverage": "hardhat coverage"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^25.3.5",
    "hardhat": "^2.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
