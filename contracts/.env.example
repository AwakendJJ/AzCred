# ============================================================
# AzCred Contracts — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Deployer private key (no 0x prefix needed)
PRIVATE_KEY=your_private_key_here

# Creditcoin EVM Testnet RPC (default is the public endpoint)
CREDITCOIN_TESTNET_RPC=https://rpc.cc3-testnet.creditcoin.network

# Set to "true" to enable gas cost reporting during tests
REPORT_GAS=false
