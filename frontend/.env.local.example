# ============================================================
# AzCred Frontend — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# WalletConnect Project ID — get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Deployed contract addresses (populated after contracts are deployed)
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS=
NEXT_PUBLIC_VALIDATION_REGISTRY_ADDRESS=
NEXT_PUBLIC_AZCRED_CREDIT_LINE_ADDRESS=
